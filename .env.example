# Copy this file to `.env` and fill in your values.
# Grab a free key from https://console.groq.com/keys

# Required for --approach llm and --approach hybrid (and --compare)
GROQ_API_KEY=

# Optional — override the default model. llama-3.3-70b-versatile is free-tier.
# Other free-tier choices: llama-3.1-8b-instant, openai/gpt-oss-20b
# GROQ_MODEL=llama-3.3-70b-versatile
